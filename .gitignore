# Dependencies
node_modules/

# Environment & secrets
.env
.env.local
.env.*.local
*.pem
*.key

# Build outputs — frontend / Vite
dist/
*.tsbuildinfo

# Electron
electron/dist/
release/
out/
.cache/
.electron-dev-data/
build-resources/*
# Track tray icon source SVGs and generated PNGs (the rest of build-resources
# contains chrome binaries downloaded by electron-builder).
!build-resources/owl_*.svg
!build-resources/owl_*.png
# Track app icons used by electron-builder.
!build-resources/icon.icns
!build-resources/icon.ico
!build-resources/icon.png
# Track DMG installer background (generated by scripts/generate-dmg-background.py).
!build-resources/dmg-background.png
!build-resources/dmg-background@2x.png
# Track NSIS installer sidebars.
!build-resources/installerSidebar.bmp
!build-resources/uninstallerSidebar.bmp
# Track TTF font sources used by scripts/generate-dmg-background.py.
!build-resources/fonts/
!build-resources/fonts/*.ttf

# Local runtime state (SQLite, logs)
userData/

# whisper.cpp binaries + model — bundled at package time, not in git
resources/whisper/*/whisper-cli
resources/whisper/*/whisper-cli.exe
resources/whisper/*.bin
resources/whisper/*.dat

# Local build cache
.cache/

# Vite dev port handoff (written by vite, read by electron)
.bisbi-dev-port

# Logs & temp
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs_temp.txt

# OS
.DS_Store
Thumbs.db
Desktop.ini

proxy.md
